import GQSVT.gqsp_angles;
import GQSVT.func_approx;
import QRISP.TFIM_slq;
import GQSVT.matrix_poly;

def jacobi_anger_coeffs(n:!ℕ,t:!ℝ){
    p := vector(2*n+1,0:!ℂ);
    p[n] = bessj0(t);
    for r in [1..n+1){
        c := (-1i)^r * bessj(r,t);
        p[n-r] = c; p[n+r] = c;  
    }
    return p;
}

def time_evolution[n:!ℕ,m:!ℕ](const f:𝔹^m × 𝔹^n → mfree 𝔹^m × 𝔹^n)(anc:𝔹^(m+1),qs:𝔹^n,t:!ℝ,α:!ℝ,d:!ℕ) mfree{
    //p := jacobi_anger_coeffs(d,α*t);
    //q := complement[2*d](p,1e-8);
    //assert(is_complement[num_samples(2*d,1e-8)][2*d](p,q,1e-8));
	//(θs,φs,λ) := gqsp_compute_angles[2*d](p,q);
    θs := [0.05160475393453347,1.2499553199601279,2.981937567255218,1.7606963625215464,1.9998063072909584,2.950330378757213,0.33873559717243995,2.883392647652459,2.2033693404703314,2.4669415881826118,2.7546059385047164,1.861636538425057,2.891837886486046,1.4213357935258626,2.9178202575362575,1.4424535768485864,2.8867635306812813,1.9105202133349872,2.7365684862411124,2.508401170267737,2.1283976658104233,2.9022687303486854,0.1910720499224809,2.9395107138329397,2.10860268679217,1.6213984020806125,2.9886752466726345,1.3749898017693216,3.08748289394363]:!ℝ^29;
    φs := [-3.110649508891693,1.6190671626535458,0.044962259034517636,-1.530023287298672,0.0431507503335704,-1.5301918006677404,-3.1344877701756206,-1.5315096817762182,-3.1053209846248357,-1.5292622264062898,-3.1082458814524365,-1.5367075568580357,-3.1074284004067687,-1.5195604553787148,-3.110109449088182,-1.5432802417360323,-3.1089975422675544,-1.5240602568623232,-3.112609904706668,-1.5398288546156684,-3.108507179694481,-1.5340476872709272,3.0468661261695753,-1.537437399573035,0.03357610097497338,-1.5341079172522918,0.03859433376591735,1.618925616358127,0.09246198694242166]:!ℝ^29;
    λ := -3.141592653589793;
    (anc,qs) := gqet[14][2*14](θs,φs,λ)(f)(anc,qs);
    return (anc,qs);
}

def main(){
    return time_evolution[2,2](TFIM[sqrt(0.25),sqrt(0.5)][2,2])(0:uint[3] as 𝔹^3,0:uint[2] as 𝔹^2,π/4,1.25,14);
}
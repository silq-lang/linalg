import QRISP.pauli_lcu;

def TFIM[J:!в„ќ,h:!в„ќ][n:!в„•,m:!в„•](anc:рќ”№^m,qs:рќ”№^n) mfree:рќ”№^mГ—рќ”№^n{
    assert(n>1);
	coef := vector(n sub 1,J)~vector(n,h);
	(ind_z, ind_x) := ([(0:!в„•,3*2^k) for k in [0..n sub 1)], [(2^k,0:!в„•) for k in [0..n)]);
    return pauli_LCU[m,n,n sub 1 + n coerce !в„•](anc,qs,ind_z~ind_x,coef);
}

def main(){
    return TFIM[-sqrt(0.25),sqrt(0.5)][2,2](0:uint[2] as рќ”№^2,0:uint[2] as рќ”№^2);
}
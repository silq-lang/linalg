def main(){
    Оє := 0.23;
    Пµ := 1e-8;
    k := (sqrt(2)/Оє)*sqrt(log(2/ПЂ/Пµ^2));
    n := floor((1/Оє)*log(1/Пµ)) coerce !в„•;
    print(n,k);
    return pe_poly(19,10)
}
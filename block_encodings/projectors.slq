import multicontrol;

def block_projector[n:!в„•](anc:рќ”№^1,qs:рќ”№^n,const f:рќ”№^n в†’ mfree рќ”№^n) mfree{
    anc[0] := X(H(anc[0]));
    (anc,) := anc;
    anc := mc_sub(Z)(f,qs,anc);
    anc := H(X(Z(anc)));
    return (anc,qs);
}

def Up(qs:рќ”№^1) mfree{
    qs[0] := X(qs[0]);
    return qs;
}

def main(){
    qs := 0:uint[1] as рќ”№^1;
    qs[0]:=H(qs[0]);
    (anc,qs) := block_projector(0:uint[1] as рќ”№^1,qs,Up);
    return (anc,qs);
}
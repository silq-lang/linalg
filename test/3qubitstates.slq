def toW[n:!в„•](qs:рқ”№^n)mfree:рқ”№^n{
  if n==1{ qs[0]:=X(qs[0]); }
  else if n>1{
    (head,)~tail:=qs;
    Оё:=2В·asin(1/sqrt(n)); 
    head:=rotY(Оё,head); // |0вҹ© вҶҰ cos(Оё/2)|0вҹ© + sin(Оё/2)|1вҹ©
    if !head { tail := toW(tail); }
    qs:=(head,)~tail;
  }
  return qs;
}

def solve(qs:рқ”№^3):!в„•{
  if qs[1]{ phase(-2В·ПҖ/3); } 
  if qs[2]{ phase(-4В·ПҖ/3); }
  qs:=reverse(toW[3])(qs);
  return measure(qs as int[3])!=0;
}

def generate_input_state(state:!рқ”№){
  // prepare ПҲ_0 (state=false) or ПҲ_1 (state=true)
  qs:=vector(3,0:рқ”№);
  qs:=toW[3](qs);
  if state{
    if qs[1]{ phase(4В·ПҖ/3); }
    else if qs[2]{ phase(2В·ПҖ/3); }
  }else{
    if qs[1]{ phase(2В·ПҖ/3); }
    else if qs[2]{ phase(4В·ПҖ/3); }
  }
  return qs;
}

def main(){
  ПҲ_0:=generate_input_state(false);
  ПҲ_1:=generate_input_state(true);
  check0:=solve(ПҲ_0);
  check1:=solve(ПҲ_1);
  return (check0,check1);
}


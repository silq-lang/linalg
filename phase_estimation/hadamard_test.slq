import primitives.multicontrol;
import phase_estimation.QPE;

def real_hadamard_test[n:!в„•](const f:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),const g:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),xs:рќ”№^n) mfree{
    (flag:рќ”№^1)~(qs:рќ”№^(n sub 1)) := xs;
    qs := g(qs);
    flag[0] := H(flag[0]);
    qs := mc(f)(flag,qs);
    flag[0] := H(flag[0]);
    return (flag~qs);
}

def imag_hadamard_test[n:!в„•](const f:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),const g:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),xs:рќ”№^n) mfree{
    (flag:рќ”№^1)~(qs:рќ”№^(n sub 1)) := xs;
    qs := g(qs);
    flag[0] := H(flag[0]);
    if flag[0]=1{phase(-ПЂ/2);}
    qs := mc(f)(flag,qs);
    flag[0] := H(flag[0]);
    return (flag~qs);
}

def real_expectation_value[shots:!в„•][n:!в„•,m:!в„•](const f:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),const g:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1))(const window:!в„ќ в†’ qfree !в„ќ ,const anc:рќ”№^m,const qs:рќ”№^n){
    def real_had_test(xs:рќ”№^n) mfree{return real_hadamard_test(f,g,xs);}
    def G_real(xs:рќ”№^n) mfree{
        if xs[0]=0{phase(ПЂ);}
        with real_had_test(xs):=xs{
            if xs==vector(n,0){phase(ПЂ);}
        }
        return xs;
    }
    tr := estimate_phase[shots][n,m](G_real)(window,anc,qs);
    return (2*(cos(ПЂ*tr))^2-1) 
}

def imag_expectation_value[shots:!в„•][n:!в„•,m:!в„•](const f:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1),const g:рќ”№^(n sub 1) в†’ mfree рќ”№^(n sub 1))(const window:!в„ќ в†’ qfree !в„ќ ,const anc:рќ”№^m,const qs:рќ”№^n){
    def imag_had_test(xs:рќ”№^n) mfree{return imag_hadamard_test(f,g,xs);}
    def G_imag(xs:рќ”№^n) mfree{
        if xs[0]=0{phase(ПЂ);}
        with imag_had_test(xs):=xs{
            if xs==vector(n,0){phase(ПЂ);}
        }
        return xs;
    }
    ti := estimate_phase[shots][n,m](G_imag)(window,anc,qs);
    return (2*(cos(ПЂ*ti))^2-1);
}

def cP(x:рќ”№^1){
    if x[0]=1{phase(ПЂ/2);}
    phase(ПЂ);
    return x;
}

def Up(x:рќ”№^1){
    x[0] := H(x[0]);
    return x;
}

def main(){
    return real_expectation_value[10][2,5](cP,Up)(sine_window[5],0:uint[5] as рќ”№^5,2:uint[2] as рќ”№^2);
    //return imag_expectation_value[10][2,5](cP,Up)(sine_window[5],0:uint[5] as рќ”№^5,0:uint[2] as рќ”№^2);
}
def fft[N:!鈩昡(xs:!鈩俕N):!鈩俕N {
	if N=1 { return xs; }
	assert(N%2=0);
	xs_e:=vector(N div 2,0);
	xs_o:=vector(N div 2,0);
	for j in 0..N div 2{
		xs_e[j]=xs[2路j];
		xs_o[j]=xs[2路j+1];
	}
	ys_e:=fft(xs_e);
	ys_o:=fft(xs_o);
	ys:=vector(N,0);
	for k in 0..N div 2{
		t:=cis(-2路蟺路k/N)路ys_o[k];
		ys[k]=ys_e[k]+t;
		ys[k+N div 2]=ys_e[k]-t;
	}
	return ys;
}
def ifft[N:!鈩昡(ys:!鈩俕N):!鈩俕N {
	for i in 0..N{ ys[i]:=conj(ys[i]); }
	xs:=fft(ys);
	for i in 0..N{ xs[i]:=conj(xs[i])/N; }
	return xs;
}